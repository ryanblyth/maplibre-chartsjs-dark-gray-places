{
  "name": "my-custom-map-fixed",
  "version": "1.0.0",
  "description": "Custom MapLibre basemap: My Custom Map Fixed",
  "type": "module",
  "scripts": {
    "prepare": "npm run build:utils",
    "build:styles": "tsx scripts/build-styles.ts",
    "build:styles:local": "SPRITE_CDN=http://localhost:8080 tsx scripts/build-styles.ts",
    "verify:tilejson": "node scripts/verify-tilejson.mjs",
    "build:shields": "tsx scripts/build-shields.ts",
    "build:utils": "tsc --project tsconfig.browser.json",
    "build": "npm run build:utils && npm run build:styles",
    "serve": "node serve.js",
    "dev": "npm run build:utils && npm run build:styles:local && npm run serve"
  },
  "devDependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "@types/node": "^20.10.0",
    "maplibre-gl": "^4.0.0",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.0",
    "sharp": "^0.34.5",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
